{
    "$schema": "https://ui.shadcn.com/schema/registry.json",
    "name": "mithril",
    "homepage": "https://github.com/bbatchelder/mithril",
    "items": [
        {
            "name": "tokens",
            "type": "registry:style",
            "title": "Design tokens",
            "description": "Blueprint-faithful design tokens (palette, intents, surfaces, elevation, type, motion) as Tailwind v4 @theme + light/dark CSS variables. The foundation every component builds on.",
            "files": [
                {
                    "path": "src/styles/tokens.css",
                    "type": "registry:file",
                    "target": "src/styles/tokens.css"
                }
            ]
        },
        {
            "name": "utils",
            "type": "registry:lib",
            "title": "cn() utility",
            "description": "The `cn` class-merging helper (clsx + tailwind-merge), taught mithril's custom font-size scale so size and color utilities don't collide.",
            "dependencies": [
                "clsx",
                "tailwind-merge"
            ],
            "files": [
                {
                    "path": "src/lib/utils.ts",
                    "type": "registry:lib",
                    "target": "lib/utils.ts"
                }
            ]
        },
        {
            "name": "types",
            "type": "registry:lib",
            "title": "Shared types",
            "description": "Cross-component TypeScript types (the `Intent` vocabulary) defined once so every control shares one source of truth. Dependency-free.",

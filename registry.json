{
    "$schema": "https://ui.shadcn.com/schema/registry.json",
    "name": "analyst-ui",
    "homepage": "https://github.com/bbatchelder/analyst-ui",
    "items": [
        {
            "name": "tokens",
            "type": "registry:style",
            "description": "Blueprint-faithful design tokens (palette, intents, surfaces, elevation, type, motion) as Tailwind v4 @theme + light/dark CSS variables.",
            "files": [
                {
                    "path": "src/styles/tokens.css",
                    "type": "registry:file",
                    "target": "src/styles/tokens.css"
                }
            ]
        },
        {
            "name": "button",
            "type": "registry:ui",
            "description": "Button — solid/outlined/minimal variants, five intents, three sizes, loading/active/fill states, start/end icons. Blueprint-faithful, built on CVA + Radix Slot.",
            "dependencies": ["@radix-ui/react-slot", "class-variance-authority", "lucide-react"],
            "registryDependencies": ["https://registry/tokens"],
            "files": [
                {
                    "path": "src/components/ui/button.tsx",
                    "type": "registry:ui",
                    "target": "components/ui/button.tsx"
                }
            ]
        }
    ]
}

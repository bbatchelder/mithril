{
    "name": "@bbatchelder/mithril",
    "version": "0.0.0",
    "private": true,
    "description": "A modern, pixel-faithful reimplementation of Palantir Blueprint's design language — built on React 19, Radix primitives, Tailwind v4, and CVA. Distributed shadcn-style as owned source.",
    "type": "module",
    "license": "Apache-2.0",
    "packageManager": "pnpm@11.4.0",
    "homepage": "https://github.com/bbatchelder/mithril",
    "repository": {
        "type": "git",
        "url": "https://github.com/bbatchelder/mithril.git"
    },
    "bugs": {
        "url": "https://github.com/bbatchelder/mithril/issues"
    },
    "keywords": [
        "blueprint",
        "blueprintjs",
        "design-system",
        "react",
        "tailwindcss",
        "radix-ui",
        "cva",
        "shadcn",
        "components",
        "ui"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc -b --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck:test": "tsc -p tsconfig.test.json",
        "gen:icons": "node tools/gen-icons.mjs",
        "gen:meta": "node tools/gen-component-meta.mjs",
        "gen:props": "node tools/gen-component-props.mjs",
        "gen:registry": "node tools/gen-registry.mjs",
        "build:registry": "pnpm dlx shadcn@4.9.0 build registry.json --output dist/r && node tools/rewrite-registry-urls.mjs"
    },
    "dependencies": {
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.1.1",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.26",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "culori": "^4.0.2",
        "maplibre-gl": "^5.24.0",
        "react": "^19.0.0",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.0.0",
        "react-dropzone": "^15.0.0",
        "tailwind-merge": "^2.6.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/culori": "^4.0.1",
        "@types/node": "^22.10.5",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.0",
        "axe-core": "^4.11.4",
        "jsdom": "^29.1.1",
        "pixelmatch": "^7.2.0",
        "pngjs": "^7.0.0",
        "react-docgen-typescript": "^2.4.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    }
}

{
    "name": "@bbatchelder/mithril",
    "version": "0.0.0",
    "private": false,
    "description": "A modern, pixel-faithful reimplementation of Palantir Blueprint's design language — built on React 19, Radix primitives, Tailwind v4, and CVA. Distributed both as a conventional npm package and shadcn-style as owned source.",
    "type": "module",
    "license": "Apache-2.0",
    "packageManager": "pnpm@11.4.0",
    "homepage": "https://github.com/bbatchelder/mithril",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bbatchelder/mithril.git"
    },
    "bugs": {
        "url": "https://github.com/bbatchelder/mithril/issues"
    },
    "keywords": [
        "blueprint",
        "blueprintjs",
        "design-system",
        "react",
        "tailwindcss",
        "radix-ui",
        "cva",
        "shadcn",
        "components",
        "ui"
    ],
    "sideEffects": false,
    "main": "./dist-lib/index.js",
    "module": "./dist-lib/index.js",
    "types": "./dist-lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist-lib/index.d.ts",
            "import": "./dist-lib/index.js"
        },
        "./icons": {
            "types": "./dist-lib/components/ui/icons/index.d.ts",
            "import": "./dist-lib/components/ui/icons/index.js"
        },
        "./icons/all": {
            "types": "./dist-lib/components/ui/icons/all.d.ts",
            "import": "./dist-lib/components/ui/icons/all.js"
        },
        "./lib/utils": {
            "types": "./dist-lib/lib/utils.d.ts",
            "import": "./dist-lib/lib/utils.js"
        },
        "./styles.css": "./dist-lib/mithril.css",
        "./tokens.css": "./dist-lib/tokens.css",
        "./base.css": "./dist-lib/base.css",
        "./*": {
            "types": "./dist-lib/components/ui/*.d.ts",
            "import": "./dist-lib/components/ui/*.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist-lib"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc -b --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck:test": "tsc -p tsconfig.test.json",
        "gen:icons": "node tools/gen-icons.mjs",
        "gen:meta": "node tools/gen-component-meta.mjs",
        "gen:props": "node tools/gen-component-props.mjs",
        "gen:barrel": "node tools/gen-barrel.mjs",
        "gen:registry": "node tools/gen-registry.mjs",
        "build:registry": "pnpm dlx shadcn@4.9.0 build registry.json --output dist/r && node tools/rewrite-registry-urls.mjs",
        "build:css": "tailwindcss -i src/styles/index.css -o dist-lib/mithril.css --minify",
        "build:lib": "pnpm gen:barrel && vite build --config vite.lib.config.ts && node tools/fix-dts-extensions.mjs && pnpm build:css && node tools/copy-lib-assets.mjs",
        "check:pkg": "pnpm build:lib && publint --strict && attw --pack . --profile esm-only --exclude-entrypoints styles.css tokens.css base.css"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "dependencies": {
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.1.1",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.26",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "react-day-picker": "^10.0.1",
        "react-dropzone": "^15.0.0",
        "tailwind-merge": "^2.6.0"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.3",
        "@tailwindcss/cli": "^4.3.0",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/culori": "^4.0.1",
        "@types/node": "^22.10.5",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.0",
        "axe-core": "^4.11.4",
        "culori": "^4.0.2",
        "jsdom": "^29.1.1",
        "maplibre-gl": "^5.24.0",
        "pixelmatch": "^7.2.0",
        "pngjs": "^7.0.0",
        "publint": "^0.3.21",
        "react": "^19.0.0",
        "react-docgen-typescript": "^2.4.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.0",
        "vite": "^8.0.0",
        "vite-plugin-dts": "^5.0.2",
        "vitest": "^4.1.0"
    }
}

{
    "name": "analyst-ui",
    "version": "0.0.0",
    "private": true,
    "description": "A modern, pixel-faithful reimplementation of Palantir Blueprint's design language — built on React 19, Radix primitives, Tailwind v4, and CVA. Distributed shadcn-style as owned source.",
    "type": "module",
    "license": "Apache-2.0",
    "packageManager": "pnpm@10.30.3",
    "homepage": "https://github.com/bbatchelder/analyst-ui",
    "repository": {
        "type": "git",
        "url": "https://github.com/bbatchelder/analyst-ui.git"
    },
    "bugs": {
        "url": "https://github.com/bbatchelder/analyst-ui/issues"
    },
    "keywords": [
        "blueprint",
        "blueprintjs",
        "design-system",
        "react",
        "tailwindcss",
        "radix-ui",
        "cva",
        "shadcn",
        "components",
        "ui"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc -b --noEmit",
        "gen:icons": "node tools/gen-icons.mjs",
        "gen:registry": "node tools/gen-registry.mjs"
    },
    "dependencies": {
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.1.1",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.2.8",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "maplibre-gl": "^5.24.0",
        "react": "^19.0.0",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^2.6.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^22.10.5",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "pixelmatch": "^7.2.0",
        "pngjs": "^7.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.2",
        "vite": "^6.0.7"
    }
}
